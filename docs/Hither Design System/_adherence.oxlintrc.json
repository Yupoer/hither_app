{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/forms/**",
              "components/glass/**",
              "components/hither/**",
              "ui_kits/hither_ios/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Fredoka|Plus Jakarta Sans))/i]",
        "message": "Font not provided by the design system. Available: Fredoka, Plus Jakarta Sans."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|emoji|src|color|size|ring|dimmed|leader|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: label, emoji, src, color, size, ring, dimmed, leader, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:signal|sky|pink|cyan|success|sun|neutral)$/]",
        "message": "<Avatar> color must be one of 'signal' | 'sky' | 'pink' | 'cyan' | 'success' | 'sun' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Banner'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|tone|style|children|key|ref|className|style|children)$/]",
        "message": "<Banner> doesn't accept that prop. Declared props: icon, tone, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Banner'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:signal|sky|success|neutral)$/]",
        "message": "<Banner> tone must be one of 'signal' | 'sky' | 'success' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|full|disabled|iconLeft|iconRight|style|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, full, disabled, iconLeft, iconRight, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|success|ghost|glass)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'success' | 'ghost' | 'glass'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:lg|sm)$/]",
        "message": "<Button> size must be one of 'lg' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:elevated|glow|padding|style|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: elevated, glow, padding, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='glow'] > Literal[value!=/^(?:signal|sky|pink|success)$/]",
        "message": "<Card> glow must be one of 'signal' | 'sky' | 'pink' | 'success'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DistanceChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:time|distance|size|tone|layout|style|key|ref|className|style|children)$/]",
        "message": "<DistanceChip> doesn't accept that prop. Declared props: time, distance, size, tone, layout, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DistanceChip'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|lg)$/]",
        "message": "<DistanceChip> size must be one of 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DistanceChip'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|accent)$/]",
        "message": "<DistanceChip> tone must be one of 'default' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DistanceChip'] > JSXAttribute[name.name='layout'] > Literal[value!=/^(?:stack|inline)$/]",
        "message": "<DistanceChip> layout must be one of 'stack' | 'inline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='GatherPointRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|trailing|tileTone|onClick|style|key|ref|className|style|children)$/]",
        "message": "<GatherPointRow> doesn't accept that prop. Declared props: icon, title, trailing, tileTone, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='GatherPointRow'] > JSXAttribute[name.name='tileTone'] > Literal[value!=/^(?:success|accent|sky)$/]",
        "message": "<GatherPointRow> tileTone must be one of 'success' | 'accent' | 'sky'."
      },
      {
        "selector": "JSXOpeningElement[name.name='GlassSurface'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|weight|tint|sheen|style|children|key|ref|className|style|children)$/]",
        "message": "<GlassSurface> doesn't accept that prop. Declared props: variant, weight, tint, sheen, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='GlassSurface'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:pane|pill|sheet|capsule)$/]",
        "message": "<GlassSurface> variant must be one of 'pane' | 'pill' | 'sheet' | 'capsule'."
      },
      {
        "selector": "JSXOpeningElement[name.name='GlassSurface'] > JSXAttribute[name.name='weight'] > Literal[value!=/^(?:regular|thin|heavy)$/]",
        "message": "<GlassSurface> weight must be one of 'regular' | 'thin' | 'heavy'."
      },
      {
        "selector": "JSXOpeningElement[name.name='GlassSurface'] > JSXAttribute[name.name='tint'] > Literal[value!=/^(?:accent|sky|success)$/]",
        "message": "<GlassSurface> tint must be one of 'accent' | 'sky' | 'success'."
      },
      {
        "selector": "JSXOpeningElement[name.name='GroupChipMember'] > JSXAttribute > JSXIdentifier[name!=/^(?:emoji|label|color|key|ref|className|style|children)$/]",
        "message": "<GroupChipMember> doesn't accept that prop. Declared props: emoji, label, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|tone|disabled|style|children|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: size, tone, disabled, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|signal|sky|glass)$/]",
        "message": "<IconButton> tone must be one of 'neutral' | 'signal' | 'sky' | 'glass'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|placeholder|iconLeft|type|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: value, onChange, placeholder, iconLeft, type, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MapControlItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|onClick|active|key|ref|className|style|children)$/]",
        "message": "<MapControlItem> doesn't accept that prop. Declared props: icon, onClick, active."
      },
      {
        "selector": "JSXOpeningElement[name.name='MemberMarker'] > JSXAttribute > JSXIdentifier[name!=/^(?:emoji|label|color|size|pulse|gather|style|key|ref|className|style|children)$/]",
        "message": "<MemberMarker> doesn't accept that prop. Declared props: emoji, label, color, size, pulse, gather, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MemberMarker'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:signal|sky|pink|cyan|success|sun|plum|neutral)$/]",
        "message": "<MemberMarker> color must be one of 'signal' | 'sky' | 'pink' | 'cyan' | 'success' | 'sun' | 'plum' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MemberRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:emoji|label|name|color|status|time|distance|you|leader|statusTone|divider|style|key|ref|className|style|children)$/]",
        "message": "<MemberRow> doesn't accept that prop. Declared props: emoji, label, name, color, status, time, distance, you, leader, statusTone, divider, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MemberRow'] > JSXAttribute[name.name='statusTone'] > Literal[value!=/^(?:muted|success)$/]",
        "message": "<MemberRow> statusTone must be one of 'muted' | 'success'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pill'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|soft|style|children|key|ref|className|style|children)$/]",
        "message": "<Pill> doesn't accept that prop. Declared props: color, soft, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pill'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:signal|sky|pink|cyan|success|sun|neutral)$/]",
        "message": "<Pill> color must be one of 'signal' | 'sky' | 'pink' | 'cyan' | 'success' | 'sun' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressDots'] > JSXAttribute > JSXIdentifier[name!=/^(?:total|active|style|key|ref|className|style|children)$/]",
        "message": "<ProgressDots> doesn't accept that prop. Declared props: total, active, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='RolePill'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|dotColor|onClick|style|key|ref|className|style|children)$/]",
        "message": "<RolePill> doesn't accept that prop. Declared props: label, dotColor, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Segmented'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|value|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Segmented> doesn't accept that prop. Declared props: options, value, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, onChange, disabled, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
