{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "node": "22.16.0",
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "node": "22.16.0",
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_DIAGNOSTICS_ENABLED": "true",
        "EXPO_PUBLIC_DIAGNOSTIC_LEVEL": "verbose"
      }
    },
    "androidQa": {
      "node": "22.16.0",
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_DIAGNOSTICS_ENABLED": "true",
        "EXPO_PUBLIC_DIAGNOSTIC_LEVEL": "verbose"
      }
    },
    "diagnostic": {
      "node": "22.16.0",
      "distribution": "store",
      "autoIncrement": true,
      "channel": "diagnostic",
      "env": {
        "EXPO_PUBLIC_DIAGNOSTICS_ENABLED": "true",
        "EXPO_PUBLIC_DIAGNOSTIC_LEVEL": "verbose"
      }
    },
    "production": {
      "node": "22.16.0",
      "distribution": "store",
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_DIAGNOSTICS_ENABLED": "true",
        "EXPO_PUBLIC_DIAGNOSTIC_LEVEL": "minimal",
        "EXPO_PUBLIC_PERFORMANCE_TRACING": "full"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6790314569"
      }
    }
  }
}
