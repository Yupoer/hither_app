{
  "expo": {
    "name": "Hither",
    "slug": "hither",
    "scheme": "hither",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "bundleIdentifier": "app.hither.mobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Hither 需要你的位置，才能在地圖上顯示你與下一個集合點的距離。",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "導航期間即使鎖定螢幕，Hither 仍需要你的位置來更新與集合點的距離和抵達狀態。",
        "NSSupportsLiveActivities": true,
        "UIBackgroundModes": [
          "location",
          "remote-notification"
        ]
      },
      "entitlements": {
        "aps-environment": "production"
      }
    },
    "android": {
      "package": "app.hither.mobile",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Hither 需要你的位置，才能在地圖上顯示你與下一個集合點的距離。",
          "locationAlwaysAndWhenInUsePermission": "導航期間即使鎖定螢幕，Hither 仍需要你的位置來更新與集合點的距離和抵達狀態。",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      "expo-notifications",
      "@bacons/apple-targets",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      "expo-apple-authentication"
    ]
  }
}
