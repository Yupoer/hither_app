{
  "expo": {
    "name": "Hither",
    "slug": "hither",
    "scheme": "hither",
    "version": "0.1.3",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/0f62ed14-1f2e-4d7b-b5b6-4eda273f2e35",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "appleTeamId": "5LBPG5TUKP",
      "bundleIdentifier": "app.hither.mobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Hither 需要你的位置，才能在地圖上顯示你與下一個集合點的距離。",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "導航期間即使鎖定螢幕，Hither 仍需要你的位置來更新與集合點的距離和抵達狀態。",
        "NSSupportsLiveActivities": true,
        "NSSupportsLiveActivitiesFrequentUpdates": true,
        "UIBackgroundModes": [
          "location",
          "remote-notification"
        ]
      },
      "entitlements": {
        "aps-environment": "production",
        "com.apple.developer.applesignin": [
          "Default"
        ]
      }
    },
    "android": {
      "package": "app.hither.mobile",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Hither 需要你的位置，才能在地圖上顯示你與下一個集合點的距離。",
          "locationAlwaysAndWhenInUsePermission": "導航期間即使鎖定螢幕，Hither 仍需要你的位置來更新與集合點的距離和抵達狀態。",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      "expo-notifications",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      "expo-apple-authentication",
      "expo-sqlite"
    ],
    "extra": {
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "bundleIdentifier": "app.hither.mobile.widget",
                  "targetName": "HitherActivityWidget"
                }
              ]
            }
          }
        },
        "projectId": "0f62ed14-1f2e-4d7b-b5b6-4eda273f2e35"
      }
    },
    "owner": "yupoer"
  }
}
