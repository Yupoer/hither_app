# Copy to apps/mobile/.env and fill locally. Never commit real secrets.

# Supabase (client)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Google Maps SDK for Android (injected by app.config.ts into AndroidManifest)
GOOGLE_MAPS_ANDROID_API_KEY=

# Optional override for Firebase Android client config path
# GOOGLE_SERVICES_JSON=./google-services.json
